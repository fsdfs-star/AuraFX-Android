<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aero_bg_start">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/aero_shell_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/aero_tab_bg"
                android:orientation="horizontal">
                
                <TextView
                    android:id="@+id/tabPlaylist"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Плейлист"
                    android:textColor="@color/aero_tab_active_text"
                    android:background="@color/aero_tab_active_bg"
                    android:textSize="12sp" />
                
                <TextView
                    android:id="@+id/tabEffects"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Эффекты"
                    android:textColor="@color/aero_tab_text"
                    android:textSize="12sp" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/aero_shell_bg">
                
                <LinearLayout
                    android:id="@+id/contentPlaylist"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <Button
                        android:id="@+id/btnUpload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Добавить музыку" />
                        
                    <ListView
                        android:id="@+id/playlistView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/contentEffects"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Скорость" android:textColor="@color/text_dark"/>
                    <SeekBar android:id="@+id/speedSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="200" android:progress="100"/>
                    
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Тон (Pitch)" android:textColor="@color/text_dark" android:layout_marginTop="16dp"/>
                    <SeekBar android:id="@+id/pitchSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="24" android:progress="12"/>
                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@color/aero_screen_start"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">
                
                <ImageView
                    android:id="@+id/albumArt"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="#ffffff"
                    android:src="@android:drawable/ic_media_play" />
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:id="@+id/trackName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Загрузите музыку"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/trackArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#444444"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/aero_controls_bg"
                android:orientation="vertical"
                android:padding="16dp">
                
                <SeekBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">
                    
                    <ImageButton
                        android:id="@+id/btnPlay"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/play_btn_bg"
                        android:src="@android:drawable/ic_media_play"
                        android:tint="@color/text_light" />
                        
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
